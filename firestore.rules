rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function allowlist() {
      return get(/databases/$(database)/documents/config/allowlist).data;
    }

    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email in allowlist().emails;
    }

    function isParent() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email == allowlist().parentEmail;
    }

    // The role is derived from the allowlist server-side, never trusted
    // from the client: a student can't self-promote to "parent" (or demote
    // themselves off the dashboard).
    function roleFor() {
      return request.auth.token.email == allowlist().parentEmail
        ? "parent"
        : "student";
    }

    function validSummary(s) {
      return s is map
        && s.keys().hasOnly(["readiness", "streak", "topicMastery", "lastExam"])
        && (s.readiness is number && s.readiness >= 0 && s.readiness <= 100)
        && (s.streak is number && s.streak >= 0)
        && s.topicMastery is map
        && (!("lastExam" in s)
            || (s.lastExam is map
                && s.lastExam.keys().hasOnly(["score", "total", "passed", "at"])
                && s.lastExam.score is number
                && s.lastExam.total is number
                && s.lastExam.passed is bool
                && s.lastExam.at is number));
    }

    function validUserDoc(d) {
      return d.keys().hasOnly(["email", "displayName", "role", "lastActive", "summary"])
        && (!("email" in d) || d.email == request.auth.token.email)
        && (!("role" in d) || d.role == roleFor())
        && (!("summary" in d) || validSummary(d.summary));
    }

    // An attempt mirrors the client Attempt type (src/types.ts). hasAll guards
    // presence BEFORE the `is` checks (reading an absent key throws an eval
    // error, not false), and hasOnly rejects junk keys — which is also how a
    // bloated doc is bounded, since rules cannot measure document bytes.
    function validAttempt(d) {
      return d.keys().hasAll(["mode", "score", "total", "startedAt", "durationSec", "perTopic", "missedIds"])
        && d.keys().hasOnly(["mode", "topic", "score", "total", "passed", "startedAt", "durationSec", "perTopic", "missedIds"])
        && d.mode is string
        && d.score is number
        && d.total is number
        && d.startedAt is number
        && d.durationSec is number
        && d.perTopic is map
        && d.missedIds is list
        && (!("topic" in d) || d.topic is string)
        && (!("passed" in d) || d.passed is bool);
    }

    // The SRS state doc is exactly { entries: <map> } (src/firebase/store.ts).
    // Rules cannot measure bytes, so bound the entry COUNT — the bank is ~200
    // ids, so a legit doc is small; thousands of entries is abuse.
    function validState(d) {
      return d.keys().hasOnly(["entries"])
        && d.entries is map
        && d.entries.size() <= 1000;
    }

    match /config/allowlist {
      // The doc lists the family's emails, so only family members may read
      // it. A read of a missing doc is allowed (resource == null) so the
      // client can still diagnose "allowlist not created" during setup.
      allow read: if request.auth != null
        && (resource == null
            || request.auth.token.email in resource.data.emails);
      allow write: if false; // edited in the Firebase console only
    }

    match /users/{uid} {
      allow read: if (isAllowed() && request.auth.uid == uid) || isParent();
      allow write: if isAllowed()
        && request.auth.uid == uid
        && validUserDoc(request.resource.data);

      // NOT {document=**}: in rules_version 2 a recursive wildcard matches
      // ZERO or more segments, so it would also match /users/{uid} itself
      // and let writes bypass validUserDoc above (caught by the rules
      // tests). Subcollection docs live at exactly this depth.
      match /{collection}/{docId} {
        allow read: if (isAllowed() && request.auth.uid == uid) || isParent();
        // Only the two collections the client actually uses are writable, and
        // each must match its shape/size — an allowlisted student can't dump
        // arbitrary garbage or oversized docs into their own subtree.
        allow write: if isAllowed()
          && request.auth.uid == uid
          && ((collection == "attempts" && validAttempt(request.resource.data))
              || (collection == "state" && validState(request.resource.data)));
      }
    }
  }
}
