{
  "name": "ar-driver-quiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "test:rules": "firebase emulators:exec --only firestore --project demo-ar-driver-quiz 'vitest run tests/rules'",
    "validate-bank": "node scripts/validate-bank.mjs",
    "normalize-bank": "node scripts/normalize-bank.mjs",
    "audit-tells": "vite-node scripts/audit-tells.ts",
    "export-parity": "TZ=UTC vite-node scripts/export-parity-vectors.ts"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "firebase-tools": "^15.20.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.0.5"
  }
}
